{
  "name": "tutor-clockwork-backend",
  "version": "1.0.0",
  "description": "Backend API для приложения репетиторских занятий",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node --env-file=.env server.js",
    "dev": "nodemon --env-file=.env server.js",
    "seed-owner": "node --env-file=.env src/database/seed-owner.js",
    "create-invite": "node --env-file=.env src/scripts/create-invite.js",
    "migrate-sqlite": "node --env-file=.env scripts/migrate-sqlite-to-pg.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.2",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "prisma": "^6.19.3",
    "sqlite3": "^5.1.6"
  }
}
